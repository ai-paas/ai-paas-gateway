# 데이터베이스 설정
# PostgreSQL URL 형식: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# API 기본 설정
API_V1_STR=/api/v1
PROJECT_NAME=AIPaaS Gateway Management API
HOST=0.0.0.0
PORT=8000
DEBUG=true
LOG_LEVEL=info

# 파일 로그 설정
LOG_DIR=var/log
LOG_FILE_ENABLED=true
LOG_ACCESS_ENABLED=true
LOG_UVICORN_ACCESS_ENABLED=false
LOG_JSON_FORMAT=false
LOG_ROTATION_MAX_BYTES=10485760
LOG_ROTATION_BACKUP_COUNT=10
LOG_ACCESS_MASK_PATHS=["/api/v1/auth/login","/api/v1/auth/refresh","/api/v1/auth/logout"]

# CORS 설정
# "*" 또는 쉼표 구분 문자열 또는 JSON 배열 문자열 사용 가능
# 예시 1) CORS_ALLOW_ORIGINS=*
# 예시 2) CORS_ALLOW_ORIGINS=http://10.0.0.1:3000,http://10.0.0.2:3000
# 예시 3) CORS_ALLOW_ORIGINS=["http://10.0.0.1:3000","http://10.0.0.2:3000"]
CORS_ALLOW_ORIGINS=*
# IP 대역/패턴이 필요하면 정규식 사용
# 예시: ^https?://10\.0\.0\.\d{1,3}(:\d+)?$
CORS_ALLOW_ORIGIN_REGEX=
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# JWT 설정
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-minimum-32-characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Refresh Token 쿠키 설정
AUTH_REFRESH_COOKIE_NAME=refresh_token
AUTH_REFRESH_COOKIE_HTTPONLY=true
AUTH_REFRESH_COOKIE_SECURE=false
# cross-site 브라우저 환경이면 보통 none + https 필요
AUTH_REFRESH_COOKIE_SAMESITE=lax
AUTH_REFRESH_COOKIE_DOMAIN=
AUTH_REFRESH_COOKIE_PATH=/api/v1/auth
AUTH_REFRESH_COOKIE_MAX_AGE=604800

# 비밀번호 해시 설정
PASSWORD_HASH_SCHEMES=bcrypt

# 프록시 설정
PROXY_ENABLED=false
PROXY_TARGET_BASE_URL=https://api.example.com
PROXY_TARGET_PATH_PREFIX=/api/v1
PROXY_TIMEOUT=30.0
PROXY_CONNECT_TIMEOUT=5.0
PROXY_MAX_CONNECTIONS=100
PROXY_MAX_KEEPALIVE_CONNECTIONS=20
EXTERNAL_API_USERNAME=your-username
EXTERNAL_API_PASSWORD=your-password

# HUB Connect 설정
HUB_CONNECT_ENABLED=false
HUB_CONNECT_TARGET_BASE_URL=http://127.0.0.1:8001
HUB_CONNECT_TARGET_PATH_PREFIX=/api/v1
HUB_CONNECT_TIMEOUT=30.0
HUB_CONNECT_CONNECT_TIMEOUT=5.0
HUB_CONNECT_MAX_CONNECTIONS=100
HUB_CONNECT_MAX_KEEPALIVE_CONNECTIONS=20
HUB_CONNECT_API_USERNAME=admin
HUB_CONNECT_API_PASSWORD=change-me

# Any Cloud 설정
ANY_CLOUD_ENABLED=false
ANY_CLOUD_TARGET_BASE_URL=http://127.0.0.1:8888
ANY_CLOUD_TIMEOUT=30.0
ANY_CLOUD_CONNECT_TIMEOUT=5.0
ANY_CLOUD_MAX_CONNECTIONS=100
ANY_CLOUD_MAX_KEEPALIVE_CONNECTIONS=20

# Lite Model 설정
LITE_MODEL_ENABLED=false
LITE_MODEL_TARGET_BASE_URL=http://127.0.0.1:30007/api/v1
LITE_MODEL_TIMEOUT=30.0
LITE_MODEL_CONNECT_TIMEOUT=5.0
LITE_MODEL_MAX_CONNECTIONS=100
LITE_MODEL_MAX_KEEPALIVE_CONNECTIONS=20
